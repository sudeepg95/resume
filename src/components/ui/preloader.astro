---
<div id="preloader" class="fixed inset-0 z-[100] flex items-center justify-center bg-charcoal-50 dark:bg-charcoal-900 transition-opacity duration-500">
  <div class="text-6xl font-bold text-blue-500 animate-pulse">
    SG
  </div>
</div>

<script is:inline>
  window.addEventListener('load', () => {
    const preloader = document.getElementById('preloader');
    if (preloader) {
      preloader.style.opacity = '0';
      setTimeout(() => {
        preloader.style.display = 'none';
      }, 500); // Match the duration of the transition
    }
  });
</script>
