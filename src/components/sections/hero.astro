---
import { Icon } from 'astro-icon/components';

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/sudeepg95', icon: 'mdi:github' },
  { name: 'LinkedIn', url: 'https://linkedin.com/in/sudeepg95', icon: 'mdi:linkedin' },
  { name: 'Twitter', url: 'https://twitter.com/sudeepg95', icon: 'mdi:twitter' },
];
---

<section class="relative h-screen flex items-center justify-center text-center bg-gray-900 text-white overflow-hidden">
  <div class="absolute inset-0 bg-black opacity-50"></div>
  <div class="relative z-10 p-8">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-4 text-shadow-header">Sudeep G</h1>
    <p class="text-xl md:text-2xl text-gray-300 mb-8">Lead Software Engineer | Full-Stack Developer</p>
    <div class="flex justify-center space-x-4">
      <a href="#about" class="btn btn-primary">About Me</a>
      <a href="#contact" class="btn btn-secondary">Contact</a>
    </div>
    <div class="flex justify-center space-x-6 mt-8">
      {socialLinks.map(link => (
        <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.name} class="text-gray-400 hover:text-white transition-colors duration-300">
          <Icon name={link.icon} class="w-8 h-8" />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .btn {
    @apply inline-block px-8 py-3 rounded-full text-lg font-semibold transition-transform duration-300 transform hover:scale-105;
  }
  .btn-primary {
    @apply bg-blue-600 hover:bg-blue-700 text-white;
  }
  .btn-secondary {
    @apply bg-transparent border-2 border-white hover:bg-white hover:text-gray-900 text-white;
  }
</style>
