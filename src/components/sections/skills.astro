---
import type { Skill } from '~/utils/schemas/cv-schema';
import { Icon } from 'astro-icon/components';

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<section class="py-12 slide-in-from-left" data-animate>
  <div class="flex items-center gap-x-3 mb-6">
    <Icon name="mdi:lightbulb-on-outline" class="w-8 h-8 text-blue-500" />
    <h2 class="text-3xl font-bold">Skills & Technologies</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
    {skills.map((skill) => (
      <div class="skill-item" data-animate>
        <h3 class="text-lg font-semibold text-charcoal-700 dark:text-charcoal-200 mb-2" data-animate>{skill.name}</h3>
        <div class="w-full bg-charcoal-200 dark:bg-charcoal-700 rounded-full h-4" data-animate>
          <div
            class="skill-bar bg-blue-500 h-4 rounded-full"
            style={`--skill-level: ${skill.level}%`}
            data-animate
          >
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skill-item {
    opacity: 0;
    transition: opacity 0.5s ease-out;
  }
  .skill-item.is-visible {
    opacity: 1;
  }
  .skill-bar {
    width: 0;
    transition: width 1s ease-in-out;
  }
  .is-visible .skill-bar {
    width: var(--skill-level);
  }
</style>
