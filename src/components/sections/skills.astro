---
import type { Skill } from '~/utils/schemas/cv-schema';
import { Icon } from 'astro-icon/components';

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<section class="py-12 slide-in-from-left" data-animate>
  <div class="flex items-center gap-x-3 mb-6">
    <Icon name="mdi:lightbulb-on-outline" class="w-8 h-8 text-blue-500" />
    <h2 class="text-3xl font-bold">Skills & Technologies</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {skills.map((skill) => (
      <div class="p-6 bg-charcoal-100 dark:bg-charcoal-700 rounded-lg">
        <h3 class="text-xl font-bold text-charcoal-800 dark:text-charcoal-100 mb-4">{skill.name}</h3>
        <div class="flex flex-wrap gap-2">
          {skill.keywords.map((keyword) => (
            <span class="bg-blue-100 text-blue-800 text-sm font-medium px-3 py-1 rounded-full dark:bg-blue-900 dark:text-blue-200 transition-colors duration-300 hover:bg-blue-200 dark:hover:bg-blue-800">
              {keyword}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
