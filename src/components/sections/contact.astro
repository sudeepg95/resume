---
import { Icon } from 'astro-icon/components';

interface Props {
  email: string;
  phone?: string;
}

const { email, phone } = Astro.props;
---

<section class="py-12 fade-in" id="contact" data-animate>
  <div class="text-center">
    <Icon name="mdi:email-fast-outline" class="w-12 h-12 text-blue-500 mx-auto mb-4" />
    <h2 class="text-3xl font-bold mb-4">Get In Touch</h2>
    <p class="text-lg text-charcoal-600 dark:text-charcoal-300 max-w-2xl mx-auto mb-8">
      I'm always open to discussing new projects, creative ideas, or opportunities to be part of an ambitious vision. Feel free to reach out.
    </p>
    <div class="flex justify-center items-center gap-4">
      <a href={`mailto:${email}`} class="btn btn-primary">
        <Icon name="mdi:email-outline" class="w-5 h-5 mr-2" />
        Email Me
      </a>
      {phone && (
        <a href={`tel:${phone}`} class="btn btn-secondary">
          <Icon name="mdi:phone-outline" class="w-5 h-5 mr-2" />
          Call Me
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .btn {
    @apply inline-flex items-center px-6 py-3 rounded-full text-base font-semibold transition-all duration-300 transform hover:scale-105 hover:-translate-y-1 hover:shadow-xl;
  }
  .btn-primary {
    @apply bg-blue-600 hover:bg-blue-700 text-white shadow-lg;
  }
  .btn-secondary {
    @apply bg-white dark:bg-charcoal-700 text-charcoal-700 dark:text-charcoal-200 hover:bg-charcoal-100 dark:hover:bg-charcoal-600 shadow-lg;
  }
</style>
